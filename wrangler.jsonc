{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudotp",
  "main": "src/index.js",
  "compatibility_date": "2026-07-10",
  "workers_dev": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cloudotp-db",
      "database_id": "8d6bedb9-110c-4f43-876f-3f6bc0eec2ca",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  }
}
